# Backend servlet context path (prefixes every backend URL)
VITE_CONTEXT_PATH=/adminconsole-ux

# Dev-only: where the Vite proxy forwards backend requests.
# The proxy sends this host as the Host header, which is what the backend's
# tenant resolution (IPAddressFilter/BankIdInterceptor) keys on — so pointing
# this at a different tenant domain switches the tenant branding in dev.
VITE_BACKEND_TARGET=http://staronedev.tyfone.com
# VITE_BACKEND_TARGET=http://diamondcudev1.tyfone.com/
